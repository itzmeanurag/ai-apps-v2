# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
ADMIN_PASSWORD_HASH=$2b$12$examplehashchangeme

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db

# ── Optional: LLM-based guardrail classification ──────────────────────────────
OPENAI_API_KEY=sk-...          # only if using OpenAI for classification
ANTHROPIC_API_KEY=...          # only if using Anthropic

# ── MCP Server ───────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8080
MCP_API_KEY=your-mcp-api-key

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development        # development | staging | production
LOG_LEVEL=INFO
